diff --git a/src/expand/expand_param.c b/src/expand/expand_param.c
index fef58bad..ff223f2f 100644
--- a/src/expand/expand_param.c
+++ b/src/expand/expand_param.c
@@ -171,7 +171,7 @@ expand_param(struct nargparam* param, union node** nptr, int flags) {
 
         /* $$ arg subst */
       case S_PID: {
-        stralloc_catulong0(&value, sh_pid, 0);
+        stralloc_catulong0(&value, sh_shpid, 0);
         break;
       }
