diff --git a/lib/wait/wait_pid_nohang.c b/lib/wait/wait_pid_nohang.c
index 1c479fe0..033c48fd 100644
--- a/lib/wait/wait_pid_nohang.c
+++ b/lib/wait/wait_pid_nohang.c
@@ -13,13 +13,25 @@ wait_pid_nohang(int pid, int* wstat) {
 #if WINDOWS_NATIVE
   DWORD exitcode = 0;
   HANDLE process = OpenProcess(SYNCHRONIZE | PROCESS_QUERY_INFORMATION, FALSE, pid);
-  WaitForSingleObject(process, INFINITE);
+
+  if(!process)
+    return -1;
+
+  /* 0 timeout -- this is the *_nohang() variant, it must poll and
+     return immediately instead of blocking until pid exits */
+  if(WaitForSingleObject(process, 0) != WAIT_OBJECT_0) {
+    CloseHandle(process);
+    return 0;
+  }
+
   GetExitCodeProcess(process, &exitcode);
   CloseHandle(process);
   wait_track_remove(pid);
 
   if(exitcode == STILL_ACTIVE)
-    return -1;
+    return 0;
+
+  *wstat = exitcode;
   return pid;
 #else
   int w = 0;
