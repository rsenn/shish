diff --git a/src/var/var_copys.c b/src/var/var_copys.c
index 22ef3f4b..b678dcd8 100644
--- a/src/var/var_copys.c
+++ b/src/var/var_copys.c
@@ -19,5 +19,7 @@ var_copys(const char* s, int flags) {
   if(var->sa.len > var->len)
     var->offset = var->len + 1;
 
